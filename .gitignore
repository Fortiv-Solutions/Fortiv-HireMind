# ============================================================
# Fortiv HireMind — .gitignore
# ============================================================

# ─── Dependencies ────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ─── Build outputs ───────────────────────────────────────────
dist/
dist-ssr/
build/
out/
.output/

# ─── Environment variables (NEVER commit secrets) ────────────
.env
.env.local
.env.*.local
.env.development
.env.production
.env.staging
.env.test

# ─── Logs ────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ─── TypeScript cache ────────────────────────────────────────
*.tsbuildinfo

# ─── Vite cache ──────────────────────────────────────────────
.vite/
vite.config.ts.timestamp-*

# ─── Test coverage ───────────────────────────────────────────
coverage/
.nyc_output/

# ─── Editor & OS artifacts ───────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store
Thumbs.db
desktop.ini

# ─── Temporary / scratch files ───────────────────────────────
*.local
*.tmp
*.temp
tmp/
temp/

# ─── Package manager lockfiles (keep one, ignore others) ─────
# If you use npm → commit package-lock.json, ignore the rest:
yarn.lock
pnpm-lock.yaml
# If you use pnpm → swap the above lines accordingly.

# ─── Kiro IDE ────────────────────────────────────────────────
.kiro/

# ─── Miscellaneous ───────────────────────────────────────────
.cache/
.eslintcache
.stylelintcache
*.map
storybook-static/